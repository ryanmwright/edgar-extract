# Copy to .env and fill in your values. .env is gitignored.
# The flake's shellHook auto-sources this on `nix develop`.

# Required. SEC EDGAR requires a descriptive User-Agent identifying
# the requester on every request. Convention: app name + contact email.
EDGAR_USER_AGENT="Fund X-Ray your-email@example.com"

# Optional. Without a key, OpenFIGI fallback runs at the keyless rate
# (10 CUSIPs per batch, ~25 req/min). With a key: 100 CUSIPs/batch,
# ~250 req/min. Request one at https://www.openfigi.com/api
# OPENFIGI_API_KEY=""
